{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "puzzle.schema.json",
  "title": "Trend Eng Puzzle Schema",
  "description": "가로세로 영어 퀴즈 퍼즐 데이터 스키마. 스킬이 이 규격에 맞게 JSON을 생성하면 puzzle.html이 자동으로 렌더링합니다.",
  "type": "object",
  "required": ["version", "meta", "grid", "words"],

  "properties": {

    "version": {
      "type": "string",
      "description": "스키마 버전",
      "const": "1.0"
    },

    "meta": {
      "type": "object",
      "description": "퍼즐 메타 정보",
      "required": ["id", "title", "date", "category", "difficulty"],
      "properties": {
        "id": {
          "type": "string",
          "description": "퍼즐 고유 ID. 형식: puzzle-{YYYYMMDD}-{3자리 순번}",
          "pattern": "^puzzle-\\d{8}-\\d{3}$",
          "example": "puzzle-20260321-001"
        },
        "title": {
          "type": "string",
          "description": "퍼즐 제목 (한국어 가능)",
          "maxLength": 60,
          "example": "AI 기술 영어 퀴즈"
        },
        "date": {
          "type": "string",
          "description": "생성 날짜 (YYYY-MM-DD)",
          "format": "date",
          "example": "2026-03-21"
        },
        "category": {
          "type": "string",
          "description": "퍼즐 주제 카테고리",
          "enum": ["tech", "sports", "entertainment", "politics", "economy", "popsong", "general"]
        },
        "difficulty": {
          "type": "string",
          "description": "난이도",
          "enum": ["easy", "medium", "hard"]
        },
        "source": {
          "type": "string",
          "description": "출처 (뉴스 제목, 팝송명 등). 선택 항목.",
          "maxLength": 100,
          "example": "Google Gemini 2.5 발표 뉴스"
        }
      },
      "additionalProperties": false
    },

    "grid": {
      "type": "object",
      "description": "그리드 크기",
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "description": "열 수 (최소 8, 최대 15)",
          "minimum": 8,
          "maximum": 15
        },
        "height": {
          "type": "integer",
          "description": "행 수 (최소 8, 최대 15)",
          "minimum": 8,
          "maximum": 15
        }
      },
      "additionalProperties": false
    },

    "words": {
      "type": "array",
      "description": "퍼즐에 배치된 단어 목록",
      "minItems": 3,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "number", "answer", "clue", "clue_ko", "direction", "startX", "startY"],
        "properties": {
          "id": {
            "type": "string",
            "description": "단어 고유 ID. 형식: w{순번}",
            "pattern": "^w\\d+$",
            "example": "w1"
          },
          "number": {
            "type": "integer",
            "description": "힌트 번호 (좌→우, 위→아래 순서로 배정)",
            "minimum": 1
          },
          "answer": {
            "type": "string",
            "description": "정답 영단어 (반드시 대문자)",
            "pattern": "^[A-Z]{2,15}$",
            "example": "GEMINI"
          },
          "clue": {
            "type": "string",
            "description": "영어 힌트 문장",
            "minLength": 5,
            "maxLength": 200,
            "example": "Google's most capable AI model."
          },
          "clue_ko": {
            "type": "string",
            "description": "한국어 힌트 번역",
            "minLength": 2,
            "maxLength": 200,
            "example": "구글의 가장 강력한 AI 모델."
          },
          "direction": {
            "type": "string",
            "description": "단어 방향",
            "enum": ["across", "down"]
          },
          "startX": {
            "type": "integer",
            "description": "단어 시작 열 위치 (1-indexed, 1 이상)",
            "minimum": 1
          },
          "startY": {
            "type": "integer",
            "description": "단어 시작 행 위치 (1-indexed, 1 이상)",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },

  "additionalProperties": false,

  "examples": [
    {
      "version": "1.0",
      "meta": {
        "id": "puzzle-20260321-001",
        "title": "AI 기술 영어 퀴즈",
        "date": "2026-03-21",
        "category": "tech",
        "difficulty": "medium",
        "source": "Google Gemini 2.5 발표 뉴스"
      },
      "grid": { "width": 10, "height": 10 },
      "words": [
        {
          "id": "w1", "number": 1,
          "answer": "GEMINI",
          "clue": "Google's most capable AI model.",
          "clue_ko": "구글의 가장 강력한 AI 모델.",
          "direction": "across", "startX": 1, "startY": 1
        },
        {
          "id": "w2", "number": 2,
          "answer": "MIND",
          "clue": "The element of a person that enables them to be aware of the world.",
          "clue_ko": "사람이 세상을 인식할 수 있게 하는 요소.",
          "direction": "down", "startX": 3, "startY": 1
        }
      ]
    }
  ],

  "skill_instructions": {
    "description": "스킬이 이 스키마로 퍼즐 데이터를 생성할 때 반드시 지켜야 할 규칙",
    "crossword_rules": [
      "단어는 반드시 최소 1개 이상 다른 단어와 교차(공통 글자 공유)해야 함",
      "교차점이 아닌 셀끼리 인접하면 안 됨: 가로 단어 행과 다른 가로 단어 행 사이에 최소 1행 공백 필요",
      "같은 방향(가로/가로, 세로/세로)의 단어는 바로 붙어있으면 안 됨",
      "단어 시작 전·끝 다음 셀은 빈칸이어야 함 (같은 방향 연속 금지)",
      "교차하는 셀의 글자는 두 단어에서 반드시 동일해야 함"
    ],
    "numbering_rules": [
      "number는 그리드를 좌→우, 위→아래로 스캔하며 단어 시작 셀 순서대로 배정",
      "같은 셀에서 가로와 세로 단어가 동시에 시작하면 동일한 number 공유"
    ],
    "content_rules": [
      "answer는 반드시 대문자 영문자만 사용 (A-Z, 2~15글자)",
      "clue는 영어로, clue_ko는 한국어 번역으로 작성",
      "단어는 뉴스/팝송의 핵심 영어 단어를 선정",
      "difficulty: easy(4~5글자 단어 위주), medium(5~8글자), hard(7글자 이상+복잡한 교차)"
    ]
  }
}
